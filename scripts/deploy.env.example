# STRATO-Zugang fuer scripts/deploy_strato.sh

STRATO_DEPLOY_USER="stu123456789"
STRATO_DEPLOY_HOST="ssh.strato.de"
STRATO_DEPLOY_PORT="22"
STRATO_SSH_KEY="$HOME/.ssh/id_ed25519"
# Optional, z. B. bei STRATO-Warnungen wie "bad signature for RSA key 0"
STRATO_SSH_EXTRA_OPTS="-o UpdateHostKeys=no"

# Basisverzeichnis laut Runbook
STRATO_APP_ROOT="/home/${STRATO_DEPLOY_USER}/apps/wollradar"
STRATO_WEB_ROOT="/home/${STRATO_DEPLOY_USER}/htdocs/wollradar_web"
STRATO_WEB_APP_SYMLINK="live"
STRATO_REMOTE_UPLOAD_DIR="${STRATO_APP_ROOT}/incoming_upload"
# Optional abweichendes Ziel nur fuer scp, z. B. "~/incoming_upload"
STRATO_REMOTE_UPLOAD_TARGET="${STRATO_REMOTE_UPLOAD_DIR}"
STRATO_REMOTE_PREPARE_SCRIPT="${STRATO_APP_ROOT}/deploy_release.sh"
STRATO_REMOTE_SWITCH_SCRIPT="${STRATO_APP_ROOT}/deploy_switch.sh"
STRATO_REMOTE_STATUS_SCRIPT="${STRATO_APP_ROOT}/deploy_status.sh"

# Lokale Release-Artefakte
DEPLOY_APP_NAME="wollradar"
RELEASE_OUTPUT_DIR="/Users/rainerrichter/VsLocal/_releases"
